<view class="page">
  <!-- 顶部搜索 header -->
  <view class="search-header">
    <view class="back-btn" bindtap="goBack">
      <view class="icon icon-back-arrow"></view>
    </view>
    <view class="search-bar">
      <text class="search-bar-icon">🔍</text>
      <input
        class="search-bar-input"
        placeholder="搜作品、画室、同学…"
        placeholder-class="search-placeholder"
        value="{{keyword}}"
        bindinput="onInput"
        bindconfirm="onSearch"
        confirm-type="search"
        focus="{{true}}"
      />
      <view wx:if="{{keyword}}" class="search-clear" bindtap="clearInput">
        <text style="font-size:28rpx;color:#bbb">✕</text>
      </view>
    </view>
    <text class="search-cancel" bindtap="goBack">取消</text>
  </view>

  <!-- 内容区 -->
  <scroll-view scroll-y class="search-scroll">

    <!-- 加载中 -->
    <view wx:if="{{loading}}" class="loading-spinner"></view>

    <!-- 未搜索提示 -->
    <view wx:elif="{{!searched}}" class="search-hint">
      <text class="search-hint-icon">🎨</text>
      <text class="search-hint-text">输入关键词搜索帖子内容</text>
    </view>

    <!-- 无结果 -->
    <view wx:elif="{{results.length === 0}}" class="empty-state">
      <text class="empty-icon">🔍</text>
      <text class="empty-text">没有找到「{{keyword}}」相关内容</text>
    </view>

    <!-- 搜索结果 -->
    <block wx:else>
      <view class="result-count">找到 {{results.length}} 条相关帖子</view>
      <post-card
        wx:for="{{results}}"
        wx:key="id"
        post="{{item}}"
        bindtap="onCardTap"
        bindlike="onLike"
        bindfavorite="onFavorite"
      />
    </block>

  </scroll-view>
</view>
