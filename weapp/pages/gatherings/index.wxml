<view class="page page-has-tabbar">
  <view class="header">
    <view class="header-left">
      <view class="back-btn" bindtap="goHome">
        <view class="icon icon-back-arrow"></view>
        <text>首页</text>
      </view>
    </view>
    <text class="header-title">攒个局</text>
    <view class="header-right"></view>
  </view>

  <!-- 两个主按钮 -->
  <view class="main-tabs">
    <view class="main-tab {{tab === 'all' ? 'main-tab-active' : ''}}" bindtap="switchTab" data-tab="all">全部局</view>
    <view class="main-tab {{tab === 'joined' ? 'main-tab-active' : ''}}" bindtap="switchTab" data-tab="joined">我加入的</view>
  </view>

  <!-- 全部局：类目筛选 -->
  <block wx:if="{{tab === 'all'}}">
    <scroll-view scroll-x class="type-scroll">
      <view wx:for="{{types}}" wx:key="key" class="type-chip {{currentType === item.key ? 'type-chip-active' : ''}}" bindtap="switchType" data-type="{{item.key}}">
        {{item.name}}
      </view>
    </scroll-view>
  </block>

  <!-- 列表 -->
  <scroll-view scroll-y class="list-scroll" bindscrolltolower="loadMore" lower-threshold="100"
    refresher-enabled refresher-triggered="{{refreshing}}" bindrefresherrefresh="onRefresh">
    <view wx:if="{{loading}}" class="loading-wrap"><view class="loading-spinner"></view></view>
    <block wx:else>
      <!-- 全部局 -->
      <block wx:if="{{tab === 'all'}}">
        <view wx:if="{{gatherings.length === 0}}" class="empty-state">
          <text class="empty-icon">🎯</text>
          <text class="empty-text">还没有局，去发起一个吧</text>
        </view>
        <view wx:for="{{gatherings}}" wx:key="id" class="gathering-item {{item.gather_closed ? 'item-closed' : ''}}" bindtap="goPost" data-id="{{item.id}}">
          <view class="item-header">
            <text class="item-type-tag">🎯 {{item.gather_type_name}}</text>
            <text class="item-status {{item.gather_closed ? 'status-closed' : 'status-open'}}">{{item.gather_closed ? '已结束' : '招募中'}}</text>
          </view>
          <text class="item-content">{{item.content}}</text>
          <view class="item-meta">
            <text class="item-meta-text">📅 {{item.gather_time}}</text>
            <text class="item-meta-text">📍 {{item.gather_place}}</text>
          </view>
          <view class="item-footer">
            <view class="item-author" catchtap="goUserProfile" data-uid="{{item.user_id}}">
              <image wx:if="{{item.display_avatar}}" src="{{item.display_avatar}}" mode="aspectFill" class="item-avatar" />
              <view wx:else class="item-avatar-placeholder">{{item.display_name ? item.display_name[0] : '用'}}</view>
              <text class="item-author-name">{{item.display_name || '用户'}}</text>
            </view>
            <text class="item-spots {{item.gather_closed ? 'spots-closed' : ''}}">
              {{item.gather_closed ? '已结束' : '还差' + item.gather_spots_left + '人'}}
            </text>
          </view>
        </view>
        <view wx:if="{{loadingMore}}" class="loading-wrap"><view class="loading-spinner"></view></view>
      </block>

      <!-- 我加入的 -->
      <block wx:elif="{{tab === 'joined'}}">
        <view wx:if="{{joined.length === 0}}" class="empty-state">
          <text class="empty-icon">🙋</text>
          <text class="empty-text">还没有加入任何局</text>
        </view>
        <view wx:for="{{joined}}" wx:key="id" class="gathering-item {{item.gather_closed ? 'item-closed' : ''}}" bindtap="goPost" data-id="{{item.id}}">
          <view class="item-header">
            <text class="item-type-tag">🎯 {{item.gather_type_name}}</text>
            <text class="item-status {{item.gather_closed ? 'status-closed' : 'status-open'}}">{{item.gather_closed ? '已结束' : '招募中'}}</text>
          </view>
          <text class="item-content">{{item.content}}</text>
          <view class="item-meta">
            <text class="item-meta-text">📅 {{item.gather_time}}</text>
            <text class="item-meta-text">📍 {{item.gather_place}}</text>
          </view>
          <view class="item-footer">
            <view class="item-author" catchtap="goUserProfile" data-uid="{{item.user_id}}">
              <image wx:if="{{item.display_avatar}}" src="{{item.display_avatar}}" mode="aspectFill" class="item-avatar" />
              <view wx:else class="item-avatar-placeholder">{{item.display_name ? item.display_name[0] : '用'}}</view>
              <text class="item-author-name">{{item.display_name || '用户'}}</text>
            </view>
            <text class="item-joined-badge">✅ 已报名</text>
          </view>
        </view>
      </block>
    </block>
    <view style="height:40rpx;"></view>
  </scroll-view>

  <view class="launch-bar" bindtap="goCreate">
    <text class="launch-bar-text">＋ 发起攒局</text>
  </view>

</view>
