<view class="page">
  <view class="header">
    <view class="header-left"><view class="back-btn" bindtap="goBack"><text>‹ 返回</text></view></view>
    <text class="header-title">二手集市</text>
    <view class="header-right"></view>
  </view>

  <scroll-view scroll-x class="type-bar">
    <view wx:for="{{categories}}" wx:key="key" class="type-item {{currentCategory === item.key ? 'type-active' : ''}}" bindtap="switchCategory" data-key="{{item.key}}">
      <text>{{item.name}}</text>
    </view>
  </scroll-view>
  <scroll-view scroll-x class="type-bar" style="padding-top:0;">
    <view wx:for="{{tags}}" wx:key="key" class="type-item tag-item {{currentTag === item.key ? 'type-active' : ''}}" bindtap="switchTag" data-key="{{item.key}}">
      <text>{{item.name}}</text>
    </view>
  </scroll-view>

  <view wx:if="{{loading && posts.length === 0}}" class="loading-spinner"></view>
  <block wx:elif="{{posts.length === 0}}">
    <view class="empty-state">
      <text class="empty-icon">🏪</text>
      <text class="empty-text">暂无商品</text>
    </view>
  </block>
  <block wx:else>
    <view wx:for="{{posts}}" wx:key="id" class="post-card" bindtap="goPost" data-id="{{item.id}}">
      <view class="post-header">
        <view class="post-avatar" catchtap="goUserProfile" data-uid="{{item.user_id}}">
          <image wx:if="{{item.display_avatar}}" src="{{item.display_avatar}}" mode="aspectFill" class="avatar-img" lazy-load />
          <view wx:else class="avatar-placeholder">{{item.display_name ? item.display_name[0] : '用'}}</view>
        </view>
        <view class="post-meta">
          <text class="post-name">{{item.display_name || '用户'}}</text>
        </view>
        <text class="post-price">¥{{item.price}}</text>
      </view>
      <view class="post-content">{{item.content}}</view>
      <view wx:if="{{item._imageCount > 0}}" class="post-img-grid post-img-grid-{{item._imageCount}}">
        <image
          wx:for="{{item._parsedImages}}"
          wx:for-item="imgUrl"
          wx:key="*this"
          src="{{imgUrl}}"
          mode="aspectFill"
          class="grid-img"
          style="{{item._imgCellStyle}}"
          lazy-load
        />
      </view>
      <view class="post-tags-row">
        <text class="tag tag-primary">{{item._market_tag_name}}</text>
        <text class="tag">{{item._market_cat_name}}</text>
      </view>
      <view class="post-actions">
        <text class="action-btn">💬 {{item.comment_count || 0}}</text>
      </view>
    </view>
    <view wx:if="{{loadingMore}}" class="loading-spinner"></view>
  </block>
</view>
