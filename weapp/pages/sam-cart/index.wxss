.cart-scroll { flex: 1; padding-bottom: 32rpx; }

.cart-item { display: flex; align-items: center; background: var(--card); margin: 16rpx 32rpx; padding: 20rpx; border-radius: var(--radius); box-shadow: var(--shadow); }
.cart-item-img-wrap { width: 96rpx; height: 96rpx; border-radius: var(--radius-sm); overflow: hidden; background: #f2f2f7; flex-shrink: 0; }
.cart-item-img { width: 100%; height: 100%; }
.cart-item-img-ph { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 36rpx; }
.cart-item-body { flex: 1; min-width: 0; margin-left: 20rpx; }
.cart-item-name { display: block; font-size: 26rpx; color: var(--text); margin-bottom: 8rpx; }
.cart-item-price { font-size: 26rpx; font-weight: 600; color: var(--danger); }
.cart-item-unit { font-size: 20rpx; font-weight: 400; color: var(--text3); }

.cart-stepper { display: flex; align-items: center; gap: 16rpx; margin-left: 16rpx; }
.stepper-btn { width: 44rpx; height: 44rpx; border-radius: 50%; background: #f2f2f7; display: flex; align-items: center; justify-content: center; font-size: 24rpx; color: var(--text2); }
.stepper-num { font-size: 26rpx; min-width: 36rpx; text-align: center; }

.cart-remove { margin-left: 16rpx; padding: 8rpx; font-size: 24rpx; color: var(--text3); }

.note-card { margin: 16rpx 32rpx; padding: 24rpx; background: var(--card); border-radius: var(--radius); box-shadow: var(--shadow); }
.note-label { font-size: 24rpx; color: var(--text2); display: block; margin-bottom: 12rpx; }
.note-required { color: var(--danger); }
.location-picker { display: flex; align-items: center; justify-content: space-between; padding: 16rpx 0; font-size: 28rpx; color: var(--text); }
.location-placeholder text:first-child { color: var(--text3); }
.location-arrow { font-size: 32rpx; color: var(--text3); }
.note-input { width: 100%; height: 100rpx; font-size: 26rpx; }

.cart-footer { display: flex; flex-direction: column; gap: 12rpx; padding: 20rpx 32rpx; background: var(--card); border-top: 0.5px solid var(--border); }
.cart-footer-total { font-size: 26rpx; color: var(--text2); }
.cart-footer-price { font-size: 32rpx; font-weight: 700; color: var(--danger); }
.cart-footer-actions { display: flex; gap: 20rpx; }
.cart-footer-btn-cancel { flex: 1; }
.cart-footer-btn { flex: 2; }

.empty-state { text-align: center; padding: 160rpx 0; }
.empty-icon { font-size: 96rpx; display: block; }
.empty-text { font-size: 28rpx; color: var(--text2); margin-top: 16rpx; display: block; }
