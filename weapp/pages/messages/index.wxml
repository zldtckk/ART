<view class="page {{convId ? 'page-flex' : ''}}">
  <view class="header">
    <view class="header-left">
      <view wx:if="{{convId}}" class="back-btn" bindtap="backToList"><text>‹ 返回</text></view>
      <view wx:else class="back-btn" bindtap="goBack"><text>‹ 返回</text></view>
    </view>
    <text class="header-title">{{convId ? (chatUser.name || '聊天') : '消息'}}</text>
    <view class="header-right"></view>
  </view>

  <!-- Tabs (only show when not in chat) -->
  <view wx:if="{{!convId}}" class="tab-bar-inline">
    <view class="tab {{tab === 'chat' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="chat">
      <text>私信</text>
      <view wx:if="{{messageUnread > 0}}" class="tab-unread-dot">
        <text class="tab-unread-dot-text">{{messageUnread > 99 ? '99+' : messageUnread}}</text>
      </view>
    </view>
    <view class="tab {{tab === 'notification' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="notification">
      <text>通知</text>
      <view wx:if="{{notificationUnread > 0}}" class="tab-unread-dot">
        <text class="tab-unread-dot-text">{{notificationUnread > 99 ? '99+' : notificationUnread}}</text>
      </view>
    </view>
  </view>

  <!-- Chat conversation list -->
  <view wx:if="{{!convId && tab === 'chat'}}">
    <view wx:for="{{conversations}}" wx:key="id" class="swipe-wrap"
      data-id="{{item._id || item.id}}"
      bindtouchstart="onSwipeStart" bindtouchmove="onSwipeMove" bindtouchend="onSwipeEnd">
      <view class="swipe-inner {{swipeOpenId === (item._id || item.id) ? 'swiped' : ''}}">
        <view class="conv-item" bindtap="onConvTap" data-convid="{{item._id || item.id}}" data-id="{{item._id || item.id}}">
          <view class="conv-avatar">
            <image wx:if="{{item.peer_avatar}}" src="{{item.peer_avatar}}" mode="aspectFill" class="conv-avatar-img" />
            <view wx:else class="avatar-placeholder" style="width:96rpx;height:96rpx;font-size:36rpx;">{{item.peer_name ? item.peer_name[0] : '?'}}</view>
          </view>
          <view class="conv-body">
            <text class="conv-name">{{item.peer_name || '用户'}}</text>
            <text class="conv-preview {{item.unread_count > 0 ? 'conv-preview-unread' : ''}}">{{item.last_message}}</text>
          </view>
          <view class="conv-right">
            <text class="conv-time">{{item.last_message_at}}</text>
            <view wx:if="{{item.unread_count > 0}}" class="conv-unread-badge">
              <text class="conv-unread-text">{{item.unread_count > 99 ? '99+' : item.unread_count}}</text>
            </view>
          </view>
        </view>
      </view>
      <view class="swipe-del" bindtap="deleteConv" data-id="{{item._id || item.id}}">
        <text class="swipe-del-text">删除</text>
      </view>
    </view>
    <view wx:if="{{conversations.length === 0}}" class="empty-state">
      <text class="empty-icon">💬</text>
      <text class="empty-text">暂无私信</text>
    </view>
  </view>

  <!-- Notifications -->
  <view wx:if="{{!convId && tab === 'notification'}}">
    <view wx:for="{{notifications}}" wx:key="id" class="swipe-wrap"
      data-id="{{item._id || item.id}}"
      bindtouchstart="onSwipeStart" bindtouchmove="onSwipeMove" bindtouchend="onSwipeEnd">
      <view class="swipe-inner {{swipeOpenId === (item._id || item.id) ? 'swiped' : ''}}">
        <view class="notif-item" bindtap="onNotifTap" data-postid="{{item.related_post_id}}" data-id="{{item._id || item.id}}">
          <view class="notif-header">
            <text class="notif-type">{{item.type === 'like' ? '❤️' : item.type === 'comment' ? '💬' : item.type === 'comment_reply' ? '↩️' : '📢'}}</text>
            <text wx:if="{{item.title}}" class="notif-title">{{item.title}}</text>
          </view>
          <text class="notif-content">{{item.content}}</text>
          <text class="notif-time">{{item.created_at}}</text>
        </view>
      </view>
      <view class="swipe-del" bindtap="deleteNotif" data-id="{{item._id || item.id}}">
        <text class="swipe-del-text">删除</text>
      </view>
    </view>
    <view wx:if="{{notifications.length === 0}}" class="empty-state">
      <text class="empty-icon">🔔</text>
      <text class="empty-text">暂无通知</text>
    </view>
  </view>

  <!-- Inline chat view -->
  <view wx:if="{{convId}}" class="chat-view">
    <scroll-view scroll-y class="message-list" scroll-top="{{scrollTop}}" scroll-with-animation>
      <view wx:for="{{messages}}" wx:key="id" class="msg {{item.sender_id === currentUserId ? 'msg-self' : 'msg-other'}}">
        <view wx:if="{{item.sender_id !== currentUserId}}" class="msg-avatar">
          <image wx:if="{{chatUser.avatar}}" src="{{chatUser.avatar}}" mode="aspectFill" class="msg-avatar-img" />
          <view wx:else class="msg-avatar-placeholder">{{chatUser.name ? chatUser.name[0] : '?'}}</view>
        </view>
        <view class="msg-bubble">
          <text wx:if="{{item.content}}" class="msg-text">{{item.content}}</text>
          <image wx:if="{{item.image_url}}" src="{{item.image_url}}" mode="widthFix" class="msg-image" />
        </view>
        <view wx:if="{{item.sender_id === currentUserId}}" class="msg-avatar">
          <image wx:if="{{selfAvatar}}" src="{{selfAvatar}}" mode="aspectFill" class="msg-avatar-img" />
          <view wx:else class="msg-avatar-placeholder">{{selfName ? selfName[0] : '我'}}</view>
        </view>
      </view>
    </scroll-view>
    <view wx:if="{{pendingImage}}" class="pending-image-bar">
      <image src="{{pendingImage}}" mode="aspectFill" class="pending-image-thumb" />
      <text class="pending-image-remove" bindtap="removePendingImage">✕</text>
    </view>
    <view class="chat-input-bar">
      <view class="chat-img-btn" bindtap="chooseImage">
        <text wx:if="{{!sendingImage}}">📷</text>
        <text wx:else>⏳</text>
      </view>
      <input class="chat-input" placeholder="输入消息..." value="{{messageText}}" bindinput="onMessageInput" confirm-type="send" bindconfirm="sendMessage" focus="{{inputFocus}}" hold-keyboard="{{true}}" />
      <text class="chat-send" bindtap="sendMessage">发送</text>
    </view>
  </view>
</view>
