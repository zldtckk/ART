.type-bar { display: flex; padding: 16rpx 32rpx; background: var(--bg); white-space: nowrap; }
.type-item { display: inline-block; padding: 12rpx 32rpx; font-size: 26rpx; background: #f2f2f7; border-radius: 32rpx; margin-right: 16rpx; }
.type-active { background: var(--accent); color: #fff; }
.header-action { font-size: 28rpx; color: var(--accent); padding: 8rpx 16rpx; }
.post-card { background: var(--card); border-radius: var(--radius); margin: 16rpx 32rpx; padding: 32rpx; box-shadow: var(--shadow); }
.post-header { display: flex; align-items: center; margin-bottom: 16rpx; }
.post-avatar { width: 64rpx; height: 64rpx; border-radius: 50%; overflow: hidden; margin-right: 16rpx; flex-shrink: 0; }
.avatar-img { width: 100%; height: 100%; }
.avatar-placeholder { width: 100%; height: 100%; background: var(--accent); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 28rpx; font-weight: 500; border-radius: 50%; }
.post-meta { flex: 1; }
.post-name { display: block; font-size: 28rpx; font-weight: 500; }
.post-tag { font-size: 20rpx !important; }
.post-content { font-size: 28rpx; line-height: 1.6; margin-bottom: 16rpx; }
.post-actions { display: flex; gap: 48rpx; padding-top: 16rpx; border-top: 0.5px solid var(--border); }
.action-btn { font-size: 26rpx; color: var(--text2); }
.empty-state { text-align: center; padding: 120rpx 0; }
.empty-icon { font-size: 96rpx; }
.empty-text { font-size: 28rpx; color: var(--text2); margin-top: 16rpx; }
.empty-hint { font-size: 24rpx; color: var(--text3); margin-top: 8rpx; }

.post-img-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 4rpx;
  margin-bottom: 20rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
}
.grid-img {
  display: block;
  background: var(--border);
  flex-shrink: 0;
}
