<view class="page">
  <view class="header">
    <view class="back-btn" bindtap="goBack"><text>‹ 返回</text></view>
    <text class="header-title">设置</text>
  </view>

  <view class="settings-form">
    <!-- Avatar -->
    <view class="settings-row" bindtap="uploadAvatar">
      <text class="settings-label">头像</text>
      <view class="settings-right">
        <view class="settings-avatar">
          <image wx:if="{{avatarUrl}}" src="{{avatarUrl}}" mode="aspectFill" class="avatar-img" />
          <view wx:else class="avatar-placeholder" style="width:80rpx;height:80rpx;font-size:32rpx;">{{nickname ? nickname[0] : '用'}}</view>
        </view>
        <text class="settings-arrow">›</text>
      </view>
    </view>

    <view class="settings-row">
      <text class="settings-label">昵称</text>
      <input class="settings-input" placeholder="设置昵称" value="{{nickname}}" bindinput="onNicknameInput" />
    </view>

    <view class="settings-row">
      <text class="settings-label">手机号</text>
      <input class="settings-input" placeholder="绑定手机号" type="number" value="{{phone}}" bindinput="onPhoneInput" />
    </view>

    <!-- Verification status -->
    <view class="settings-row">
      <text class="settings-label">认证状态</text>
      <text class="settings-value">{{user.is_verified ? '已认证' : user.verification_status === 'pending' ? '审核中' : user.verification_status === 'rejected' ? '未通过' : '未认证'}}</text>
    </view>

    <!-- Digital ID (sys_user_id) -->
    <view wx:if="{{user.sys_user_id}}" class="settings-row">
      <text class="settings-label">数字ID</text>
      <text class="settings-value">{{user.sys_user_id}}</text>
    </view>

    <button class="btn" bindtap="saveProfile">保存</button>
  </view>
</view>
