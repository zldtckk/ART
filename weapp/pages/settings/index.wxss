.settings-form { padding: 32rpx; }
.settings-row { display: flex; align-items: center; justify-content: space-between; padding: 32rpx; background: var(--card); border-radius: var(--radius-sm); margin-bottom: 2rpx; }
.settings-label { font-size: 28rpx; }
.settings-right { display: flex; align-items: center; gap: 16rpx; }
.settings-avatar { width: 80rpx; height: 80rpx; border-radius: 50%; overflow: hidden; }
.avatar-img { width: 100%; height: 100%; }
.avatar-placeholder { background: var(--accent); color: #fff; display: flex; align-items: center; justify-content: center; border-radius: 50%; }
.settings-arrow { font-size: 32rpx; color: var(--text3); }
.settings-input { text-align: right; font-size: 28rpx; color: var(--text2); flex: 1; margin-left: 32rpx; }
.settings-value { font-size: 26rpx; color: var(--text2); }
.btn { margin-top: 48rpx; }
