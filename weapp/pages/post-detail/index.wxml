<view class="page">
  <view class="header">
    <view class="back-btn" bindtap="goBack">
      <view class="icon-back-arrow"></view>
      <text>返回</text>
    </view>
    <text class="header-title">帖子详情</text>
    <view class="header-placeholder"></view>
  </view>

  <view wx:if="{{loading}}" class="loading-spinner"></view>
  <block wx:else>
    <scroll-view scroll-y class="content-scroll" lower-threshold="100">
      <!-- Post body -->
      <view class="post-card" wx:if="{{post}}" style="border-bottom:none;">
        <view class="post-header">
          <view class="post-avatar" catchtap="goUserProfile" data-uid="{{post.user_id}}">
            <image wx:if="{{post.display_avatar}}" src="{{post.display_avatar}}" mode="aspectFill" class="avatar-img" />
            <view wx:else class="avatar-placeholder">{{post.display_name ? post.display_name[0] : '用'}}</view>
          </view>
          <view class="post-author">
            <text class="post-author-name">{{post.display_name || '未知用户'}}</text>
            <view class="post-meta">
              <text class="post-meta-time">{{post.created_at}}</text>
              <text wx:if="{{post.view_count > 0}}" class="post-meta-views">👁 {{post.view_count}}</text>
              <text wx:if="{{post.circle_type}}" class="tag tag-{{post.circle_type}}">{{post.circle_type_name || post.circle_type}}</text>
              <text wx:if="{{post.studio_name}}" class="studio-badge">{{post.studio_name}}</text>
            </view>
          </view>
        </view>

        <view class="post-content">{{post.content}}</view>

        <view wx:if="{{post._parsedImages && post._parsedImages.length > 0}}" class="detail-images">
          <image wx:for="{{post._parsedImages}}" wx:key="*this" src="{{item}}" mode="widthFix" class="detail-image" lazy-load />
        </view>

        <!-- Gathering info -->
        <view wx:if="{{post.is_gathering}}" class="gathering-card">
          <view class="gathering-card-header">
            <text class="gathering-card-title">🎯 {{post.gather_type_name}} · 攒个局</text>
            <view class="gathering-status {{post.gather_closed ? 'status-closed' : 'status-open'}}">
              <text>{{post.gather_closed ? '已结束' : '招募中'}}</text>
            </view>
          </view>
          <view class="gathering-card-info">
            <view class="gathering-card-row"><text class="gathering-label">时间</text><text class="gathering-value">{{post.gather_time}}</text></view>
            <view class="gathering-card-row"><text class="gathering-label">地点</text><text class="gathering-value">{{post.gather_place}}</text></view>
            <view class="gathering-card-row">
              <text class="gathering-label">人数</text>
              <text class="gathering-value">{{post.gather_count}} / {{post.gather_limit}} 人</text>
            </view>
          </view>

          <!-- 进度条 -->
          <view class="gather-progress-bg">
            <view class="gather-progress-bar" style="width:{{post.gather_progress}}%"></view>
          </view>

          <!-- 报名按钮 -->
          <view wx:if="{{!post.gather_closed}}">
            <view wx:if="{{!isSelf}}" class="gather-join-btn {{post.is_joined ? 'join-btn-cancel' : ''}}" bindtap="handleJoin">
              <text>{{post.is_joined ? '取消报名' : '我要参加'}}</text>
            </view>
          </view>

          <!-- 二维码（仅报名者可见） -->
          <view wx:if="{{post.is_joined && post.gather_qr}}" class="qr-section">
            <text class="qr-section-title">📱 发起人微信二维码</text>
            <text class="qr-section-tip">长按识别，添加后可进群协调</text>
            <image src="{{post.gather_qr}}" mode="widthFix" class="qr-image" />
          </view>

          <!-- 发起人替换二维码 -->
          <view wx:if="{{isSelf}}" class="gather-owner-actions">
            <text class="gather-replace-qr" bindtap="handleReplaceQr">更换微信二维码</text>
          </view>

          <text class="gathering-expire-tip">局将在发起后 7 天自动结束 · 仅限认证成员参与</text>
        </view>

        <!-- Market info -->
        <view wx:if="{{post.board === 'market' && (post.price != null || post.market_tag)}}" class="market-info">
          <text wx:if="{{post.price != null}}" class="market-price">¥{{post.price}}</text>
          <text wx:if="{{post.market_tag}}" class="market-tag tag-{{post.market_tag}}">{{post.market_tag === 'buy' ? '求购' : post.market_tag === 'sell' ? '出售' : '赠送'}}</text>
        </view>

        <view class="post-footer">
          <view class="post-action {{post.is_liked ? 'post-action-active' : ''}}" bindtap="handleLike">
            <view class="icon {{post.is_liked ? 'icon-heart-active' : 'icon-heart'}}" style="width:32rpx;height:32rpx;"></view>
            <text>{{post.like_count}}</text>
          </view>
          <view class="post-action {{post.is_favorited ? 'post-action-active' : ''}}" bindtap="handleFavorite">
            <view class="icon {{post.is_favorited ? 'icon-bookmark-active' : 'icon-bookmark'}}" style="width:32rpx;height:32rpx;"></view>
            <text>{{post.is_favorited ? '已收藏' : '收藏'}}</text>
          </view>
          <view wx:if="{{isSelf}}" class="post-action post-action-danger" bindtap="handleDelete">
            <text>删除帖子</text>
          </view>
        </view>
      </view>

      <view class="divider"></view>

      <!-- Comments -->
      <view class="comments-section">
        <text class="comments-title">评论 ({{comments.length}})</text>
        <view wx:if="{{comments.length === 0}}" class="comments-empty">
          <text>暂无评论，来聊点什么吧</text>
        </view>
        <view wx:for="{{comments}}" wx:key="id" class="comment-item {{item._pending ? 'comment-pending' : ''}} {{item.parent_comment_id ? 'comment-reply' : ''}}">
          <view class="comment-avatar" catchtap="goUserProfile" data-uid="{{item.user_id}}">
            <image wx:if="{{item.display_avatar || item.avatar_url}}" src="{{item.display_avatar || item.avatar_url}}" mode="aspectFill" class="avatar-img" />
            <view wx:else class="avatar-placeholder" style="width:56rpx;height:56rpx;font-size:24rpx;">{{item.display_name ? item.display_name[0] : '用'}}</view>
          </view>
          <view class="comment-body">
            <text class="comment-name">{{item.display_name || item.nickname || '用户'}}</text>
            <view class="comment-text-wrap">
              <text wx:if="{{item.reply_to_name}}" class="reply-to" catchtap="goUserProfile" data-uid="{{item.reply_to_user_id}}">回复 @{{item.reply_to_name}}：</text>
              <text class="comment-text">{{item.content}}</text>
            </view>
            <view class="comment-footer">
              <text class="comment-time">{{item.created_at}}</text>
              <text class="comment-reply-btn" catchtap="onReply" data-id="{{item._id || item.id}}" data-name="{{item.display_name || item.nickname || '用户'}}">回复</text>
            </view>
          </view>
        </view>
      </view>

      <view style="height:160rpx;"></view>
    </scroll-view>

    <!-- Comment input bar -->
    <view wx:if="{{currentUser}}" class="comment-input-bar">
      <block wx:if="{{currentUser.is_verified}}">
        <view wx:if="{{replyingTo}}" class="reply-indicator">
          <text class="reply-indicator-text">回复 @{{replyingTo.name}}</text>
          <text class="reply-cancel" bindtap="cancelReply">✕</text>
        </view>
        <input class="comment-input" placeholder="{{replyingTo ? '回复 @' + replyingTo.name + '...' : '写评论...'}}" value="{{commentText}}" bindinput="onCommentInput" confirm-type="send" bindconfirm="handleComment" />
        <text class="comment-send-btn {{commentValid && !submitting ? '' : 'disabled'}}" bindtap="handleComment">发送</text>
      </block>
      <text wx:else class="btn btn-secondary btn-block" bindtap="goVerify" style="border-radius:40rpx;font-size:28rpx;text-align:center;">认证后即可评论</text>
    </view>
  </block>
</view>
