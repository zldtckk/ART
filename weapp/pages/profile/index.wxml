<view class="page">
  <view class="header">
    <text class="header-title">我的</text>
  </view>

  <!-- Not logged in -->
  <view wx:if="{{!isLoggedIn}}" class="empty-state">
    <view class="icon icon-profile" style="width:96rpx;height:96rpx;"></view>
    <text class="empty-title">未登录</text>
    <text class="empty-desc">登录后查看个人主页</text>
    <button class="btn" style="width:400rpx;margin-top:32rpx;" bindtap="goLogin">去登录</button>
  </view>

  <!-- Logged in -->
  <block wx:else>
    <!-- User info header -->
    <view class="profile-header">
      <view class="profile-avatar" bindtap="goSettings">
        <image wx:if="{{user.avatar_url}}" src="{{user.avatar_url}}" mode="aspectFill" class="avatar-img" />
        <view wx:else class="avatar-placeholder profile-avatar-placeholder">
          <view class="icon icon-profile-active" style="width:56rpx;height:56rpx;"></view>
        </view>
      </view>
      <view class="profile-info">
        <text class="profile-name">{{user.nickname || (user.sys_user_id ? '用户' + user.sys_user_id : '用户')}}</text>
        <text class="profile-studio">{{user.studio_name || (user.is_verified ? '' : '未认证画室')}}{{user.class_name ? ' · ' + user.class_name : ''}}</text>
      </view>
      <view class="profile-badge badge-{{user.verification_status || 'none'}}">
        {{user.is_verified ? '已认证' : user.verification_status === 'pending' ? '审核中' : '未认证'}}
      </view>
    </view>

    <!-- Entry cards -->
    <view class="profile-entries">
      <view class="profile-entry" bindtap="goMyPosts">
        <view class="entry-icon-wrap" style="background:rgba(0,122,255,0.08);">
          <view class="icon icon-document" style="width:40rpx;height:40rpx;"></view>
        </view>
        <text class="entry-label">我的帖子</text>
        <text class="entry-count">{{postCount}}</text>
        <view class="icon icon-chevron-right" style="width:32rpx;height:32rpx;"></view>
      </view>
      <view class="profile-entry" bindtap="goMyComments">
        <view class="entry-icon-wrap" style="background:rgba(52,199,89,0.08);">
          <view class="icon icon-comment" style="width:40rpx;height:40rpx;"></view>
        </view>
        <text class="entry-label">我的评论</text>
        <text class="entry-count">{{commentCount}}</text>
        <view class="icon icon-chevron-right" style="width:32rpx;height:32rpx;"></view>
      </view>
      <view class="profile-entry" bindtap="goMyFavorites">
        <view class="entry-icon-wrap" style="background:rgba(255,149,0,0.08);">
          <view class="icon icon-bookmark" style="width:40rpx;height:40rpx;"></view>
        </view>
        <text class="entry-label">我的收藏</text>
        <text class="entry-count">{{favoriteCount}}</text>
        <view class="icon icon-chevron-right" style="width:32rpx;height:32rpx;"></view>
      </view>
      <view class="profile-entry" bindtap="goMessages">
        <view class="entry-icon-wrap" style="background:rgba(255,45,85,0.08);">
          <view class="icon icon-message" style="width:40rpx;height:40rpx;"></view>
        </view>
        <text class="entry-label">消息</text>
        <view wx:if="{{unreadCount > 0}}" class="entry-unread-badge">
          <text class="entry-unread-text">{{unreadCount > 99 ? '99+' : unreadCount}}</text>
        </view>
        <view class="icon icon-chevron-right" style="width:32rpx;height:32rpx;"></view>
      </view>
    </view>

    <!-- Quick action buttons -->
    <view class="profile-actions">
      <button wx:if="{{!user.is_verified && user.verification_status !== 'pending'}}" class="btn" bindtap="goVerify" style="flex:1;font-size:26rpx;padding:16rpx 0;">去认证</button>
      <button wx:if="{{user.verification_status === 'pending'}}" class="btn btn-secondary" bindtap="goVerify" style="flex:1;font-size:26rpx;padding:16rpx 0;">查看审核状态</button>
    </view>

    <!-- Admin & Logout -->
    <view wx:if="{{user.role === 'admin' || user.role === 'circle_master'}}" class="profile-logout">
      <button class="btn btn-secondary btn-block" bindtap="goAdmin" style="font-size:28rpx;">管理后台</button>
    </view>
    <view class="profile-logout">
      <button class="btn btn-secondary btn-block" bindtap="logout" style="font-size:28rpx;">退出登录</button>
    </view>
  </block>
</view>
