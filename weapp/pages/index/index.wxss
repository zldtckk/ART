/* === B站风顶部 Header === */
.idx-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 100rpx 24rpx 16rpx;
  background: #fff;
  border-bottom: 1rpx solid var(--border);
  position: sticky;
  top: 0;
  z-index: 100;
}
.idx-logo {
  font-size: 36rpx;
  font-weight: 900;
  color: var(--text);
  letter-spacing: -1rpx;
  flex-shrink: 0;
}
.idx-search {
  flex: 1;
  background: var(--bg);
  border-radius: 32rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  gap: 10rpx;
}
.idx-search-icon { font-size: 28rpx; }
.idx-search-hint { font-size: 26rpx; color: var(--text3); }

/* === 快捷入口（B站风 1行4个） === */
.quick-entries {
  display: flex;
  padding: 20rpx 16rpx 16rpx;
  background: #fff;
  border-bottom: 1rpx solid var(--border);
}
.quick-entry {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}
.quick-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}
.quick-icon-1 { background: #fff0f4; }
.quick-icon-2 { background: #fff4e8; }
.quick-icon-3 { background: #f0f0ff; }
.quick-icon-4 { background: #f0fff4; }
.quick-label {
  font-size: 22rpx;
  color: var(--text2);
  font-weight: 500;
}

/* === 精选作品 双列 === */
.featured-wrap { background: #fff; margin-bottom: 12rpx; }
.featured-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  padding: 0 24rpx 24rpx;
}
.featured-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.featured-img {
  width: 100%;
  height: 180rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}
.featured-ph-0 { background: linear-gradient(135deg, #fff0f4, #ffc0d0); }
.featured-ph-1 { background: linear-gradient(135deg, #f0f0ff, #c8c0f8); }
.featured-ph-2 { background: linear-gradient(135deg, #f0fff4, #b0f0cc); }
.featured-ph-3 { background: linear-gradient(135deg, #fff8e0, #ffe0a0); }
.featured-ph-text { font-size: 64rpx; font-weight: 900; color: rgba(0,0,0,0.12); }
.featured-body { padding: 12rpx 14rpx 14rpx; }
.featured-title {
  font-size: 24rpx;
  color: var(--text);
  line-height: 1.45;
  margin-bottom: 10rpx;
}
.featured-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.featured-name { font-size: 20rpx; color: var(--text3); }
.featured-like { font-size: 26rpx; color: rgba(251,114,153,0.5); }
.featured-liked { color: #FB7299; }

/* === Hot posts banner === */
.hot-banner {
  margin: 16rpx 24rpx 8rpx;
  height: 120rpx;
  background: var(--card);
  border-radius: var(--radius);
  display: flex;
  overflow: hidden;
  box-shadow: var(--shadow);
}
.hot-sidebar {
  width: 20%;
  min-width: 100rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  background: #FB7299;
}
.hot-sidebar-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.3;
}
.hot-swiper {
  flex: 1;
  height: 120rpx;
}
.hot-content-wrap {
  padding: 16rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  height: 120rpx;
  box-sizing: border-box;
}
.hot-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding-right: 100rpx;
}
.hot-meta {
  font-size: 18rpx;
  color: var(--text3);
  margin-top: 4rpx;
}
.hot-item-swiper {
  display: flex;
  align-items: center;
}

/* === Verification banner === */
.verify-banner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(251,114,153,0.06);
  margin: 16rpx 24rpx 8rpx;
  padding: 20rpx 28rpx;
  border-radius: var(--radius-sm);
}
.verify-banner-text {
  font-size: 26rpx;
  color: var(--accent);
}
.verify-banner-link {
  font-size: 26rpx;
  color: var(--accent);
  font-weight: 500;
}

/* === Board entrances === */
.board-entrances {
  display: flex;
  gap: 16rpx;
  margin: 16rpx 24rpx;
}
.board-card {
  flex: 1;
  height: 100rpx;
  border-radius: 20rpx;
  padding: 0 28rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.board-card-circle {
  background: linear-gradient(135deg, #FB7299 0%, #f54f8c 100%);
}
.board-card-market {
  background: linear-gradient(135deg, #ff9500 0%, #ff6b35 100%);
}
.board-card-fan {
  background: linear-gradient(135deg, #ff2d55 0%, #ff6b9d 100%);
}
.board-card-gathering {
  background: linear-gradient(135deg, #ff9500 0%, #ffcc00 100%);
}
.board-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  line-height: 1.3;
}
.board-card-desc {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 4rpx;
}

/* === Section header === */
.section-header {
  padding: 32rpx 32rpx 16rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
  padding-left: 16rpx;
  border-left: 6rpx solid #FB7299;
}

/* === Post cards (web style: full width, border-bottom) === */
.feed-scroll { flex: 1; overflow: hidden; }
.post-card {
  background: var(--card);
  padding: 32rpx;
  border-bottom: 1rpx solid var(--border);
}
.post-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
}
.post-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
  overflow: hidden;
}
.avatar-img {
  width: 100%;
  height: 100%;
}
.avatar-placeholder {
  width: 100%;
  height: 100%;
  background: var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--text2);
  border-radius: 50%;
}
.post-author {
  flex: 1;
  min-width: 0;
}
.post-author-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
}
.post-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 4rpx;
}
.post-meta-time {
  font-size: 24rpx;
  color: var(--text3);
}
.post-chat-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--bg);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: auto;
}
.post-content {
  font-size: 30rpx;
  line-height: 1.6;
  color: var(--text);
  margin-bottom: 20rpx;
  word-break: break-word;
}

/* Images grid */
.post-img-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 4rpx;
  margin-bottom: 20rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
}
/* 所有缩略图尺寸由 JS inline style 控制，统一方块居中裁剪 */
.grid-img {
  display: block;
  background: var(--border);
  flex-shrink: 0;
}

/* Post footer */
.post-footer {
  display: flex;
  align-items: center;
  gap: 40rpx;
  font-size: 28rpx;
  color: var(--text3);
  padding-top: 16rpx;
  border-top: 0.5rpx solid var(--border);
}
.post-action {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx 0;
}
.post-action-active {
  color: #FB7299;
}

/* Tags */
.tag {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  background: var(--border-light);
  color: var(--text2);
}
.tag-general { background: rgba(251,114,153,0.08); color: var(--accent); }
.tag-anonymous { background: rgba(255,59,48,0.08); color: var(--danger); }
.tag-help { background: rgba(251,114,153,0.08); color: var(--accent); }
.tag-carpool { background: rgba(52,199,89,0.08); color: var(--success); }
.tag-food { background: rgba(255,149,0,0.08); color: var(--warning); }
.tag-other { background: rgba(0,0,0,0.04); color: var(--text2); }
.studio-badge {
  font-size: 22rpx;
  color: var(--accent);
  background: rgba(251,114,153,0.08);
  padding: 2rpx 16rpx;
  border-radius: 20rpx;
}

/* Tab bar inline (for the post type switcher) */
.tab-bar-inline {
  display: flex;
  gap: 0;
  margin: 0 24rpx 8rpx;
  overflow-x: auto;
}
.tab-bar-inline::-webkit-scrollbar { display: none; }
.tab {
  flex-shrink: 0;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  color: var(--text3);
  font-weight: 500;
  border-bottom: 4rpx solid transparent;
  transition: all 0.15s;
}
.tab-active {
  color: var(--text);
  border-bottom-color: var(--accent);
}

/* Login button */
.login-btn {
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  background: var(--accent);
  color: #fff;
  font-size: 26rpx;
}

/* Empty state */
.empty-state {
  text-align: center;
  padding: 120rpx 0;
}
.empty-icon {
  font-size: 96rpx;
}
.empty-text {
  font-size: 28rpx;
  color: var(--text2);
  margin-top: 16rpx;
}

/* Loading */
.loading-spinner {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}
.loading-spinner::after {
  content: '';
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--border);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin 0.6s linear infinite;
}
