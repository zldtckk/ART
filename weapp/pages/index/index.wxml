<view class="page page-flex">
  <!-- 固定顶部区域 -->
  <view class="top-area">
    <view class="idx-header">
      <text class="idx-logo">画室<text style="color:#FB7299">圈</text></text>
      <view class="idx-search">
        <text class="idx-search-icon">🔍</text>
        <text class="idx-search-hint">搜作品、画室、同学…</text>
      </view>
    </view>

    <!-- Verification banner -->
    <view wx:if="{{!isVerified && isLoggedIn}}" class="verify-banner" bindtap="goVerify">
      <text class="verify-banner-text">📋 认证画室成员，解锁全部功能</text>
      <text class="verify-banner-link">去认证 ›</text>
    </view>

    <!-- Hot posts banner -->
    <view wx:if="{{hotPosts.length > 0}}" class="hot-banner" bindtap="goPost" data-id="{{hotPosts[bannerIdx].id}}">
      <view class="hot-sidebar">
        <text class="hot-sidebar-text">热帖</text>
        <text class="hot-sidebar-text">排行</text>
      </view>
      <swiper class="hot-swiper" vertical autoplay interval="3500" duration="500" current="{{bannerIdx}}" bindchange="onBannerChange">
        <swiper-item wx:for="{{hotPosts}}" wx:key="id" class="hot-item-swiper">
          <view class="hot-content-wrap">
            <text class="hot-title">{{item.content}}</text>
            <text class="hot-meta">阅读量 {{item.like_count}}</text>
          </view>
        </swiper-item>
      </swiper>
    </view>

    <!-- Board entrances — B站风快捷入口 -->
    <view class="quick-entries">
      <view class="quick-entry" bindtap="goBoard" data-board="circle">
        <view class="quick-icon quick-icon-1">🖼</view>
        <text class="quick-label">画室圈子</text>
      </view>
      <view class="quick-entry" bindtap="goBoard" data-board="market">
        <view class="quick-icon quick-icon-2">🛍</view>
        <text class="quick-label">闲置交易</text>
      </view>
      <view class="quick-entry" bindtap="goBoard" data-board="fan">
        <view class="quick-icon quick-icon-3">⭐</view>
        <text class="quick-label">爱豆专区</text>
      </view>
      <view class="quick-entry" bindtap="goGatherings">
        <view class="quick-icon quick-icon-4">🎉</view>
        <text class="quick-label">攒个局</text>
      </view>
    </view>

    <!-- Latest posts header -->
    <view class="section-header">
      <view class="icon icon-trending" style="width:32rpx;height:32rpx;"></view>
      <text class="section-title">最新动态</text>
    </view>
  </view>

  <!-- 可下拉刷新的帖子列表 -->
  <scroll-view
    class="feed-scroll"
    scroll-y
    refresher-enabled
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onRefresh"
    bindscrolltolower="loadMore"
    lower-threshold="100"
  >
    <view wx:if="{{loading && posts.length === 0}}" class="loading-spinner"></view>
    <view wx:elif="{{posts.length === 0}}" class="empty-state">
      <text class="empty-icon">📭</text>
      <text class="empty-text">暂无帖子</text>
    </view>
    <block wx:else>
      <view wx:for="{{posts}}" wx:key="id" class="post-card" bindtap="goPost" data-id="{{item.id}}">
        <view class="post-header">
          <view class="post-avatar" catchtap="goUserProfile" data-uid="{{item.user_id}}" data-anon="{{item.is_anonymous}}">
            <image wx:if="{{item.display_avatar}}" src="{{item.display_avatar}}" mode="aspectFill" class="avatar-img" lazy-load />
            <view wx:else class="avatar-placeholder">{{item.is_anonymous ? '匿' : (item.display_name ? item.display_name[0] : '用')}}</view>
          </view>
          <view class="post-author">
            <view class="post-author-name">{{item.is_anonymous ? '匿名用户' : (item.display_name || '未知用户')}}</view>
            <view class="post-meta">
              <text class="post-meta-time">{{item.created_at}}</text>
              <text wx:if="{{item.circle_type}}" class="tag tag-{{item.circle_type}}">{{item.circle_type_name || item.circle_type}}</text>
              <text wx:if="{{item.studio_name}}" class="studio-badge">{{item.studio_name}}</text>
            </view>
          </view>
        </view>

        <view wx:if="{{item.content}}" class="post-content">{{item.content}}</view>

        <view wx:if="{{item._imageCount > 0}}" class="post-img-grid post-img-grid-{{item._imageCount}}">
          <image
            wx:for="{{item._parsedImages}}"
            wx:for-item="imgUrl"
            wx:key="*this"
            src="{{imgUrl}}"
            mode="aspectFill"
            class="grid-img"
            style="{{item._imgCellStyle}}"
            lazy-load
          />
        </view>

        <view class="post-footer">
          <view class="post-action">
            <view class="icon icon-comment" style="width:32rpx;height:32rpx;"></view>
            <text>{{item.comment_count || 0}}</text>
          </view>
          <view class="post-action {{item.is_liked ? 'post-action-active' : ''}}" bindtap="onLike" data-id="{{item.id}}" catchtap="onLike">
            <view class="icon {{item.is_liked ? 'icon-heart-active' : 'icon-heart'}}" style="width:32rpx;height:32rpx;"></view>
            <text>{{item.like_count || 0}}</text>
          </view>
          <view class="post-action {{item.is_favorited ? 'post-action-active' : ''}}" bindtap="onFavorite" data-id="{{item.id}}" catchtap="onFavorite">
            <view class="icon {{item.is_favorited ? 'icon-bookmark-active' : 'icon-bookmark'}}" style="width:32rpx;height:32rpx;"></view>
          </view>
        </view>
      </view>
      <view wx:if="{{loadingMore}}" class="loading-spinner"></view>
    </block>
  </scroll-view>
</view>
