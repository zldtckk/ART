<view class="page">
  <view class="header">
    <view class="header-left"><view class="back-btn" bindtap="goBack"><text>‹ 返回</text></view></view>
    <text class="header-title">我的代购订单</text>
    <view class="header-right"></view>
  </view>

  <view wx:if="{{loading}}" class="loading-spinner"></view>
  <view wx:elif="{{orders.length === 0}}" class="empty-state">
    <text class="empty-icon">🧾</text>
    <text class="empty-text">还没有下过单</text>
  </view>
  <block wx:else>
    <view wx:for="{{orders}}" wx:key="id" class="order-row" bindtap="goOrder" data-id="{{item.id}}">
      <view class="order-row-main">
        <text class="order-row-title">共{{item._count}}件商品</text>
        <text class="order-row-time">{{item._createdAt}}</text>
      </view>
      <view class="order-row-side">
        <text class="order-row-price">¥{{item.total}}</text>
        <text class="order-row-status status-{{item.status}}">{{item._statusText}}</text>
      </view>
    </view>
  </block>
</view>
