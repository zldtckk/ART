.order-row { display: flex; align-items: center; justify-content: space-between; margin: 16rpx 32rpx; padding: 28rpx 32rpx; background: var(--card); border-radius: var(--radius); box-shadow: var(--shadow); }
.order-row-main { display: flex; flex-direction: column; gap: 8rpx; }
.order-row-title { font-size: 28rpx; color: var(--text); font-weight: 500; }
.order-row-time { font-size: 22rpx; color: var(--text3); }
.order-row-side { display: flex; flex-direction: column; align-items: flex-end; gap: 8rpx; }
.order-row-price { font-size: 28rpx; font-weight: 700; color: var(--danger); }
.order-row-status { font-size: 20rpx; padding: 2rpx 16rpx; border-radius: 16rpx; }
.status-pending { background: #fff3e0; color: var(--warning); }
.status-done { background: #e6f7ed; color: var(--success); }
.status-cancelled { background: #f2f2f7; color: var(--text3); }

.empty-state { text-align: center; padding: 160rpx 0; }
.empty-icon { font-size: 96rpx; display: block; }
.empty-text { font-size: 28rpx; color: var(--text2); margin-top: 16rpx; display: block; }
