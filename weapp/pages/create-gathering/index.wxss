.page { display: flex; flex-direction: column; height: 100vh; background: #f5f5f7; }

.step-tip { display: block; font-size: 28rpx; color: #999; padding: 24rpx 32rpx 16rpx; }

/* 类目卡片 */
.type-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20rpx; padding: 0 24rpx; }
.type-card { background: #fff; border-radius: 20rpx; padding: 36rpx 28rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.type-card-name { display: block; font-size: 36rpx; font-weight: 700; color: #333; margin-bottom: 12rpx; }
.type-card-desc { display: block; font-size: 22rpx; color: #999; line-height: 1.6; }

/* 表单 */
.form-scroll { flex: 1; }
.form { padding: 24rpx 24rpx 0; }
.field { background: #fff; border-radius: 20rpx; padding: 28rpx; margin-bottom: 20rpx; }
.field-label { display: block; font-size: 26rpx; font-weight: 600; color: #333; margin-bottom: 16rpx; }
.field-tip { display: block; font-size: 22rpx; color: #999; margin-bottom: 16rpx; }
.field-input { font-size: 28rpx; color: #333; height: 72rpx; line-height: 72rpx; background: #f5f5f7; border-radius: 12rpx; padding: 0 20rpx; width: 100%; }
.field-textarea { font-size: 28rpx; color: #333; background: #f5f5f7; border-radius: 12rpx; padding: 20rpx; width: 100%; min-height: 180rpx; line-height: 1.6; }
.char-count { display: block; text-align: right; font-size: 22rpx; color: #bbb; margin-top: 8rpx; }

/* 人数滑块 */
.limit-row { display: flex; align-items: center; gap: 24rpx; }
.limit-val { font-size: 36rpx; font-weight: 700; color: #FB7299; width: 100rpx; flex-shrink: 0; }
.limit-slider { flex: 1; }

/* 二维码 */
.qr-upload { margin-top: 8rpx; }
.qr-preview { width: 240rpx; height: 240rpx; border-radius: 16rpx; }
.qr-placeholder { width: 240rpx; height: 240rpx; background: #f5f5f7; border-radius: 16rpx; border: 2rpx dashed #ccc; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12rpx; }
.qr-icon { font-size: 56rpx; color: #bbb; }
.qr-text { font-size: 24rpx; color: #bbb; }

/* 提交 */
.submit-bar { padding: 20rpx 24rpx 40rpx; }
.submit-btn { background: #FB7299; border-radius: 48rpx; padding: 30rpx 0; text-align: center; font-size: 30rpx; font-weight: 600; color: #fff; }
.submit-btn.disabled { opacity: 0.5; }
