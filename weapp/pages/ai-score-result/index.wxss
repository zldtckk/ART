.ai-score-result-page {
  --paper: #f1eee6;
  --paper-deep: #e6e0d3;
  --ink: #171713;
  --muted: #706d64;
  --line: rgba(23, 23, 19, 0.16);
  --red: #d94b38;
  background: var(--paper);
  overflow: hidden;
}

.ai-score-result-page .header {
  background: rgba(241,238,230,0.92);
  border-bottom: 1px solid var(--line);
}
.ai-score-result-page .header-title { color: var(--ink); font-weight: 700; }
.ai-score-result-page .back-btn { color: var(--red); }

.ai-score-result-page .loading-spinner::after { border-color: var(--paper-deep); border-top-color: var(--red); }

.result-scroll { flex: 1; min-height: 0; padding: 32rpx 28rpx; box-sizing: border-box; }

.card {
  background: rgba(255,255,255,0.55);
  border: 1px solid rgba(255,255,255,0.9);
  border-radius: 0;
  box-shadow: 0 20rpx 60rpx rgba(42,37,28,0.08);
  padding: 36rpx 28rpx;
  margin-bottom: 24rpx;
}

.result-header { display: flex; align-items: flex-start; justify-content: space-between; padding-bottom: 32rpx; border-bottom: 1px solid var(--line); }
.result-kicker { font-family: ui-monospace, Menlo, Consolas, monospace; font-size: 18rpx; font-weight: 700; letter-spacing: 2rpx; color: var(--red); display: block; }
.score-number { font-family: Georgia, serif; font-size: 108rpx; font-weight: 500; line-height: 1; letter-spacing: -3rpx; color: var(--red); display: block; margin-top: 8rpx; }
.score-label { font-size: 20rpx; color: var(--muted); display: block; margin-top: 10rpx; }
.tier-block { text-align: right; }
.tier-display { font-family: Georgia, "Songti SC", serif; font-size: 34rpx; font-weight: 600; color: var(--ink); display: block; }

.score-image { width: 100%; margin-top: 28rpx; border: 1px solid var(--line); display: block; }

/* ── 对比块 ──────────────────────────────────────── */
.compare-block {
  margin-top: 32rpx;
  padding: 28rpx 24rpx;
  background: var(--paper-deep);
  border-left: 3px solid var(--ink);
}
.compare-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.compare-item { display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.compare-item-label { font-size: 19rpx; color: var(--muted); letter-spacing: 1rpx; }
.compare-item-score { font-family: Georgia, serif; font-size: 72rpx; font-weight: 500; color: var(--ink); line-height: 1; }
.score-up { color: #2a7a4b; }
.score-down { color: var(--red); }
.compare-mid { display: flex; flex-direction: column; align-items: center; gap: 6rpx; }
.compare-delta { font-family: Georgia, serif; font-size: 34rpx; font-weight: 700; line-height: 1; }
.compare-arrow-line { font-size: 28rpx; color: var(--muted); }
.delta-up { color: #2a7a4b; }
.delta-down { color: var(--red); }
.delta-flat { color: var(--muted); }
.compare-verdict {
  margin-top: 22rpx;
  padding-top: 20rpx;
  border-top: 1px solid rgba(23,23,19,0.1);
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}
.verdict-label { font-size: 26rpx; font-weight: 700; white-space: nowrap; }
.verdict-sub { font-size: 21rpx; color: var(--muted); line-height: 1.6; }
.verdict-up .verdict-label { color: #2a7a4b; }
.verdict-down .verdict-label { color: var(--red); }
.verdict-flat .verdict-label { color: var(--ink); }

.dimension-list { margin-top: 32rpx; }
.dimension-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 20rpx; font-size: 22rpx; }
.dim-name { width: 132rpx; color: var(--muted); flex-shrink: 0; }
.bar { flex: 1; height: 8rpx; background: var(--paper-deep); overflow: hidden; }
.bar-fg { display: block; height: 100%; background: var(--ink); }
.dim-value { width: 44rpx; text-align: right; color: var(--ink); font-weight: 600; flex-shrink: 0; }

.feedback { margin-top: 36rpx; }
.feedback-block { margin-bottom: 26rpx; }
.feedback-h { font-size: 23rpx; font-weight: 700; color: var(--ink); display: block; margin-bottom: 10rpx; }
.feedback-p { font-size: 23rpx; color: var(--muted); line-height: 1.75; }
.feedback-li { font-size: 23rpx; color: var(--muted); line-height: 1.75; display: block; }
.teacher-comment { border-left: 3px solid var(--red); background: rgba(217,75,56,0.05); padding: 22rpx 24rpx; }

.post-copy {
  margin-top: 32rpx;
  border-top: 1px solid var(--line);
  padding-top: 28rpx;
  display: flex;
  gap: 20rpx;
  align-items: center;
}
.post-copy-text { flex: 1; font-size: 22rpx; color: var(--muted); line-height: 1.6; }
.share-button {
  border: 1px solid var(--line);
  background: transparent;
  color: var(--ink);
  padding: 14rpx 24rpx;
  font-size: 22rpx;
  border-radius: 0;
  flex-shrink: 0;
}

/* ── 专项练习计划 ──────────────────────────────── */
.plan-section {
  margin-top: 36rpx;
  border-top: 1px solid var(--line);
  padding-top: 32rpx;
}

.plan-section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 32rpx;
}
.plan-head-left { flex: 1; }
.plan-title { font-size: 26rpx; font-weight: 700; color: var(--ink); display: block; letter-spacing: 1rpx; }
.plan-desc { font-size: 19rpx; color: var(--muted); display: block; margin-top: 6rpx; }
.plan-label-tag {
  font-family: ui-monospace, Consolas, monospace;
  font-size: 17rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  color: var(--red);
  border: 1px solid rgba(217,75,56,0.35);
  padding: 8rpx 16rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
  margin-top: 2rpx;
}

.plan-item { display: flex; }
.plan-item-first { }

.plan-num-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 48rpx;
  flex-shrink: 0;
  margin-right: 24rpx;
}
.plan-num {
  width: 48rpx;
  height: 48rpx;
  background: var(--red);
  color: #fff;
  font-family: Georgia, serif;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.plan-num-line {
  width: 1px;
  flex: 1;
  min-height: 24rpx;
  background: var(--line);
  margin-top: 8rpx;
  margin-bottom: 8rpx;
}

.plan-content-col { flex: 1; min-width: 0; padding-bottom: 32rpx; }
.plan-focus-row { display: flex; align-items: flex-start; justify-content: space-between; gap: 12rpx; margin-bottom: 14rpx; }
.plan-focus { font-size: 25rpx; font-weight: 700; color: var(--ink); line-height: 1.4; flex: 1; }
.plan-freq-pill {
  background: rgba(217,75,56,0.08);
  padding: 6rpx 18rpx;
  flex-shrink: 0;
}
.plan-freq-text { font-size: 19rpx; color: var(--red); font-weight: 600; }
.plan-method { font-size: 23rpx; color: var(--muted); line-height: 1.85; display: block; }

/* 今日作业卡片 */
.hw-card {
  margin-top: 20rpx;
  background: var(--paper-deep);
  padding: 22rpx 24rpx;
  border-left: 3px solid var(--ink);
}
.hw-card-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 14rpx;
}
.hw-icon { font-size: 22rpx; }
.hw-label { font-size: 21rpx; font-weight: 700; color: var(--ink); letter-spacing: 1rpx; flex: 1; }
.hw-duration-pill { background: var(--ink); padding: 5rpx 14rpx; }
.hw-duration-text { font-size: 18rpx; color: #fff; font-weight: 600; font-family: ui-monospace, Consolas, monospace; }
.hw-task { font-size: 23rpx; color: var(--ink); line-height: 1.8; display: block; }

/* 提交作业入口 */
.plan-submit-wrap {
  margin-top: 36rpx;
  padding-top: 28rpx;
  border-top: 1px dashed var(--line);
}
.plan-submit-hint { margin-bottom: 16rpx; text-align: center; }
.plan-submit-hint-text { font-size: 21rpx; color: var(--muted); }
.plan-submit-btn {
  width: 100%;
  background: var(--ink);
  color: #f1eee6;
  font-size: 26rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  padding: 28rpx 0;
  border-radius: 0;
  border: none;
}

.again-button {
  width: 100%;
  border: 1px solid var(--line);
  border-radius: 0;
  background: transparent;
  color: var(--ink);
  padding: 24rpx;
  font-size: 26rpx;
  margin-bottom: 20rpx;
}

.disclaimer { display: block; text-align: center; font-size: 19rpx; color: var(--muted); margin-top: 8rpx; }

.result-bottom-spacer { height: 60rpx; }
