.section-title {
  font-size: 26rpx;
  color: #8e8e93;
  padding: 32rpx 32rpx 16rpx;
}

.avatar-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
  padding: 0 32rpx;
}

.avatar-cell {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 1;
  border-radius: 28rpx;
  overflow: hidden;
  border: 4rpx solid transparent;
  background: var(--card);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.avatar-cell-active {
  border-color: var(--accent);
}

.avatar-img {
  width: 100%;
  height: 100%;
  display: block;
}

.avatar-check {
  position: absolute;
  right: 8rpx;
  bottom: 8rpx;
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: 50%;
  background: var(--accent);
  color: #fff;
  font-size: 24rpx;
}

.upload-tip {
  text-align: center;
  font-size: 26rpx;
  color: #8e8e93;
  margin: 64rpx 0 20rpx;
}

.upload-btn {
  margin: 0 32rpx;
  background: var(--card);
  color: var(--accent);
  border: 2rpx solid var(--accent);
  border-radius: 16rpx;
  font-size: 30rpx;
}
