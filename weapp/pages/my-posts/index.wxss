.post-card { background: var(--card); margin: 16rpx 32rpx; padding: 32rpx; border-radius: var(--radius); box-shadow: var(--shadow); }
.post-content { font-size: 28rpx; line-height: 1.6; margin-bottom: 16rpx; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; }
.post-meta-line { display: flex; gap: 24rpx; font-size: 22rpx; color: var(--text2); }
.meta-item { }
.empty-state { text-align: center; padding: 120rpx 0; }
.empty-icon { font-size: 96rpx; }
.empty-text { font-size: 28rpx; color: var(--text2); margin-top: 16rpx; }
