<view class="page">
  <view class="header">
    <view class="header-left"><view class="back-btn" bindtap="goBack"><text>‹ 返回</text></view></view>
    <text class="header-title">爱豆交流</text>
    <view class="header-right">
      <text class="header-action" bindtap="goCreate">发帖</text>
    </view>
  </view>

  <scroll-view scroll-x class="type-bar">
    <view wx:for="{{types}}" wx:key="key"
      class="type-item {{currentType === item.key ? 'type-active' : ''}}"
      bindtap="switchType" data-type="{{item.key}}">
      <text>{{item.name}}</text>
    </view>
  </scroll-view>

  <view wx:if="{{loading && posts.length === 0}}" class="loading-spinner"></view>
  <block wx:elif="{{posts.length === 0}}">
    <view class="empty-state">
      <text class="empty-icon">⭐</text>
      <text class="empty-text">还没有帖子</text>
      <text class="empty-hint">来聊聊你的爱豆吧</text>
    </view>
  </block>
  <block wx:else>
    <view wx:for="{{posts}}" wx:key="id" class="post-card" bindtap="goPost" data-id="{{item.id}}">
      <view class="post-header">
        <view class="post-avatar" catchtap="goUserProfile" data-uid="{{item.user_id}}">
          <image wx:if="{{item.display_avatar}}" src="{{item.display_avatar}}" mode="aspectFill" class="avatar-img" lazy-load />
          <view wx:else class="avatar-placeholder">{{item.display_name ? item.display_name[0] : '用'}}</view>
        </view>
        <view class="post-meta">
          <text class="post-name">{{item.display_name || '用户'}}</text>
          <view class="post-meta-row">
            <text class="post-tag">{{item.fan_type_name || '安利'}}</text>
            <text wx:if="{{item.idol_tag}}" class="idol-tag">⭐ {{item.idol_tag}}</text>
          </view>
        </view>
        <text class="post-time">{{item.created_at}}</text>
      </view>
      <view class="post-content">{{item.content}}</view>
      <view wx:if="{{item._imageCount > 0}}" class="post-img-grid post-img-grid-{{item._imageCount}}">
        <image
          wx:for="{{item._parsedImages}}"
          wx:for-item="imgUrl"
          wx:key="*this"
          src="{{imgUrl}}"
          mode="aspectFill"
          class="grid-img"
          style="{{item._imgCellStyle}}"
          lazy-load
        />
      </view>
      <view class="post-actions">
        <view class="action-item {{item.is_liked ? 'action-active' : ''}}" catchtap="onLike" data-id="{{item.id}}">
          <text>{{item.is_liked ? '❤️' : '🤍'}} {{item.like_count || 0}}</text>
        </view>
        <view class="action-item">
          <text>💬 {{item.comment_count || 0}}</text>
        </view>
      </view>
    </view>
    <view wx:if="{{loadingMore}}" class="loading-spinner"></view>
    <view wx:if="{{!hasMore && posts.length > 0}}" class="no-more">没有更多了</view>
  </block>
</view>
