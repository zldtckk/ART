.type-bar { display: flex; padding: 16rpx 32rpx; background: var(--bg); white-space: nowrap; }
.type-item { display: inline-block; padding: 12rpx 32rpx; font-size: 26rpx; background: #f2f2f7; border-radius: 32rpx; margin-right: 16rpx; color: var(--text2); }
.type-active { background: #ff2d55; color: #fff; }

.post-card { background: var(--card); border-radius: var(--radius); margin: 16rpx 32rpx; padding: 28rpx; box-shadow: var(--shadow); }
.post-header { display: flex; align-items: center; margin-bottom: 16rpx; gap: 16rpx; }
.post-avatar { width: 64rpx; height: 64rpx; border-radius: 50%; overflow: hidden; flex-shrink: 0; }
.avatar-img { width: 100%; height: 100%; }
.avatar-placeholder { width: 100%; height: 100%; background: #ff2d55; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 28rpx; font-weight: 500; }
.post-meta { flex: 1; min-width: 0; }
.post-name { display: block; font-size: 28rpx; font-weight: 500; color: var(--text); }
.post-meta-row { display: flex; align-items: center; gap: 12rpx; margin-top: 4rpx; }
.post-tag { font-size: 20rpx; background: rgba(255,45,85,0.1); color: #ff2d55; padding: 2rpx 12rpx; border-radius: 16rpx; }
.idol-tag { font-size: 20rpx; color: var(--text3); }
.post-time { font-size: 22rpx; color: var(--text3); flex-shrink: 0; }

.post-content { font-size: 28rpx; line-height: 1.6; color: var(--text); margin-bottom: 16rpx; }

.post-img-grid { display: flex; flex-wrap: wrap; gap: 6rpx; margin-bottom: 16rpx; }
.grid-img { border-radius: 8rpx; object-fit: cover; }

.post-actions { display: flex; gap: 48rpx; padding-top: 16rpx; border-top: 0.5px solid var(--border); }
.action-item { font-size: 28rpx; color: var(--text3); }
.action-active { color: #ff2d55; }

.empty-state { text-align: center; padding: 120rpx 0; }
.empty-icon { font-size: 96rpx; display: block; }
.empty-text { font-size: 28rpx; color: var(--text2); margin-top: 16rpx; display: block; }
.empty-hint { font-size: 24rpx; color: var(--text3); margin-top: 8rpx; display: block; }
.no-more { text-align: center; font-size: 24rpx; color: var(--text3); padding: 32rpx; }
