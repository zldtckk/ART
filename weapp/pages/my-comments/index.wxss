.comment-item { background: var(--card); margin: 16rpx 32rpx; padding: 32rpx; border-radius: var(--radius); box-shadow: var(--shadow); }
.comment-bubble { font-size: 28rpx; line-height: 1.6; margin-bottom: 12rpx; padding: 20rpx 24rpx; background: #f2f2f7; border-radius: 12rpx; }
.comment-ref { font-size: 22rpx; color: var(--text3); display: block; margin-bottom: 4rpx; }
.meta-time { font-size: 20rpx; color: var(--text3); }
.empty-state { text-align: center; padding: 120rpx 0; }
.empty-icon { font-size: 96rpx; }
.empty-text { font-size: 28rpx; color: var(--text2); margin-top: 16rpx; }
