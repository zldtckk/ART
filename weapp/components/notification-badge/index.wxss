.badge-wrapper {
  position: relative;
  display: inline-block;
}

.badge {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  min-width: 28rpx;
  height: 28rpx;
  background-color: #ff3b30;
  color: #ffffff;
  font-size: 20rpx;
  line-height: 28rpx;
  text-align: center;
  border-radius: 50%;
  padding: 0 8rpx;
  box-sizing: content-box;
}

.badge-lg {
  min-width: 32rpx;
  height: 32rpx;
  font-size: 18rpx;
  line-height: 32rpx;
  padding: 0 6rpx;
}
