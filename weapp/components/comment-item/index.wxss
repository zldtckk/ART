.comment-item {
  display: flex;
  flex-direction: row;
  padding: 24rpx 32rpx;
  background-color: #ffffff;
  border-bottom: 2rpx solid #f5f5f5;
}

.comment-avatar {
  width: 48rpx;
  height: 48rpx;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.avatar-img {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
}

.avatar-placeholder {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #999;
}

.comment-body {
  flex: 1;
  min-width: 0;
}

.comment-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 8rpx;
  gap: 16rpx;
}

.comment-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}

.comment-time {
  font-size: 22rpx;
  color: #bbb;
}

.comment-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  word-break: break-all;
}
