.post-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  margin: 16rpx 32rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
}

.post-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 20rpx;
}

.post-avatar {
  width: 64rpx;
  height: 64rpx;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.avatar-img {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
}

.avatar-placeholder {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background-color: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #999;
}

.post-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.post-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  line-height: 1.4;
}

.post-time {
  font-size: 22rpx;
  color: #999;
  line-height: 1.4;
}

.post-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #ff6b35;
}

.post-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 20rpx;
  word-break: break-all;
}

.post-images {
  display: flex;
  flex-direction: row;
  margin-bottom: 20rpx;
  white-space: nowrap;
  overflow: hidden;
}

.post-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.post-tags {
  display: flex;
  flex-direction: row;
  margin-bottom: 20rpx;
  gap: 12rpx;
}

.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
}

.tag-primary {
  background-color: #e8f5e9;
  color: #2e7d32;
}

.tag-warning {
  background-color: #fff3e0;
  color: #e65100;
}

.gathering-bar { display: flex; flex-wrap: wrap; align-items: center; gap: 12rpx; background: #fff8f0; border-radius: 12rpx; padding: 16rpx 20rpx; margin-bottom: 20rpx; }
.gathering-tag { font-size: 24rpx; font-weight: 600; color: #e65100; background: #ffe0c0; padding: 4rpx 14rpx; border-radius: 8rpx; }
.gathering-info { font-size: 24rpx; color: #666; }
.spots-full { color: #999; }
.gathering-spots { font-size: 24rpx; font-weight: 600; color: #007aff; margin-left: auto; }

.post-actions {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  align-items: center;
  padding-top: 20rpx;
  border-top: 2rpx solid #f0f0f0;
}

.action-btn {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  font-size: 26rpx;
  color: #666;
}
